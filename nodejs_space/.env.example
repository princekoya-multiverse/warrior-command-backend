# ============================================================
# Warrior Command Center - Environment Variables
# ============================================================

# PostgreSQL Database
DATABASE_URL=postgresql://warrior:password@localhost:5432/warrior_command

# Qdrant Vector Store
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Abacus.AI (LLM API)
ABACUSAI_API_KEY=

# LiveKit (Real-time Communication)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# JWT Secret (for future auth)
JWT_SECRET=your-jwt-secret-change-in-production

# Redis (for caching/WebSocket state)
REDIS_URL=redis://localhost:6379

# Server Port
PORT=3000
